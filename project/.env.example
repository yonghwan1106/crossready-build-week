# Keep this value on the server. Never prefix it with NEXT_PUBLIC_.
# Requirement extraction is intentionally pinned to gpt-5.6 in server code.
OPENAI_API_KEY=

# Cost guard for live GPT-5.6 audits. Sample mode never consumes these limits.
# Defaults are 3 audits per client per 10 minutes and 10 per server process/day.
CROSSREADY_LIVE_AUDIT_CLIENT_LIMIT=3
CROSSREADY_LIVE_AUDIT_DAILY_LIMIT=10

# Per-instance protection for upload parsing and ZIP scanning (clamped 1-10).
CROSSREADY_ACTIVE_AUDIT_LIMIT=2
