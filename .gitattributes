* text=auto
.gitattributes text eol=lf
.gitignore text eol=lf
LICENSE text eol=lf

# Keep generated and visual artifacts byte-for-byte identical.
*.pdf binary
*.zip binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary

# Keep source files stable across Windows and deployment environments.
*.css text eol=lf
*.html text eol=lf
*.js text eol=lf
*.json text eol=lf
*.jsx text eol=lf
*.md text eol=lf
*.mjs text eol=lf
*.py text eol=lf
*.svg text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.txt text eol=lf
