{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crossready.dev/schemas/requirement-set.schema.json",
  "title": "CrossReady Requirement Set",
  "description": "Atomic, source-linked requirements extracted from one authoritative artifact.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "sourceArtifactId",
    "sourceTitle",
    "requirements"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "sourceArtifactId": {
      "type": "string",
      "minLength": 1
    },
    "sourceTitle": {
      "type": "string",
      "minLength": 1
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/requirement"
      }
    }
  },
  "$defs": {
    "sourceLocator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifactId",
        "locatorType",
        "locator",
        "excerpt"
      ],
      "properties": {
        "artifactId": {
          "type": "string",
          "minLength": 1
        },
        "locatorType": {
          "type": "string",
          "enum": [
            "page",
            "line",
            "section",
            "url",
            "frame",
            "metadata"
          ]
        },
        "locator": {
          "type": "string",
          "minLength": 1
        },
        "excerpt": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "statement",
        "modality",
        "scope",
        "criticality",
        "condition",
        "expectedEvidence",
        "verificationMethods",
        "source"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^REQ-[0-9]{3}$"
        },
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "modality": {
          "type": "string",
          "enum": [
            "MUST",
            "SHOULD",
            "MAY"
          ]
        },
        "scope": {
          "type": "string",
          "enum": [
            "submission",
            "product",
            "technology",
            "media",
            "repository",
            "access",
            "legal"
          ]
        },
        "criticality": {
          "type": "string",
          "enum": [
            "blocking",
            "scored",
            "advisory"
          ]
        },
        "condition": {
          "type": [
            "string",
            "null"
          ]
        },
        "expectedEvidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "verificationMethods": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "deterministic",
              "semantic",
              "visual",
              "external",
              "human"
            ]
          }
        },
        "source": {
          "$ref": "#/$defs/sourceLocator"
        }
      }
    }
  }
}
